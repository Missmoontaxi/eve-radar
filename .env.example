# Vercel KV (Upstash Redis) — stores the shared "star to rank" counts.
# Create a KV store in the Vercel dashboard (Storage → Create → KV / Upstash),
# connect it to this project, and Vercel injects these automatically in prod.
# Copy them here only for local `vercel dev` against the live store.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Read-only token (optional, not required by this app):
# KV_REST_API_READ_ONLY_TOKEN=
